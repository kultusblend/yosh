---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, PROFILE, SOCIAL } from '../consts';

// TODO: replace with real Formspree (or Web3Forms) endpoint
const FORM_ENDPOINT = 'https://formspree.io/f/YOUR_FORM_ID';

const socialEntries = Object.entries(SOCIAL).filter(
	([key, v]) => key !== 'email' && v,
);
---

<BaseLayout
	title={`Contact · ${SITE_TITLE}`}
	description="Get in touch with Noor Azree Hanifiah for advisory, training, or collaboration."
	breadcrumbs={[
		{ name: 'Home', url: '/' },
		{ name: 'Contact', url: '/contact/' },
	]}
>
	<section class="container hero">
		<div class="hero-top">
			<span class="section-index"><span class="num">CT</span> CONTACT</span>
			<span>{PROFILE.location} · MY</span>
		</div>
		<h1>Open inbox.</h1>
		<p class="lede">
			Advisory, training, atau just to compare notes on generative AI in comms. Saya baca semua, balas dalam masa 1-2 hari kerja.
		</p>
	</section>

	<section class="container section">
		<div class="grid-2 contact-grid">
			<div>
				<header class="section-head">
					<h2>Direct channels</h2>
					<span class="section-index"><span class="num">01</span> DIRECT</span>
				</header>
				<dl class="kv">
					<dt>Email</dt>
					<dd><a href={`mailto:${PROFILE.email}`}>{PROFILE.email}</a></dd>
					<dt>Phone</dt>
					<dd><a href={`tel:${PROFILE.phone.replace(/\s/g, '')}`}>{PROFILE.phone}</a></dd>
					<dt>Based</dt>
					<dd>{PROFILE.location}</dd>
				</dl>

				{socialEntries.length > 0 && (
					<div class="social-block">
						<p class="label">Social</p>
						<ul class="list-clean">
							{socialEntries.map(([key, val]) => (
								<li>
									<a href={val.startsWith('http') ? val : `https://${val}`}>
										<span class="social-key">{key}</span>
										<span class="social-val">{val}</span>
									</a>
								</li>
							))}
						</ul>
					</div>
				)}
			</div>

			<div>
				<header class="section-head">
					<h2>Send a brief</h2>
					<span class="section-index"><span class="num">02</span> FORM</span>
				</header>
				<form class="contact-form" action={FORM_ENDPOINT} method="POST">
					<div class="field">
						<label for="name">Name</label>
						<input id="name" name="name" type="text" required autocomplete="name" />
					</div>
					<div class="field">
						<label for="email">Email</label>
						<input id="email" name="email" type="email" required autocomplete="email" />
					</div>
					<div class="field">
						<label for="org">Organisation <span class="opt">(optional)</span></label>
						<input id="org" name="organisation" type="text" autocomplete="organization" />
					</div>
					<div class="field">
						<label for="intent">Intent</label>
						<select id="intent" name="intent" required>
							<option value="">Pilih satu</option>
							<option value="advisory">Advisory / consulting</option>
							<option value="training">Training / workshop</option>
							<option value="collab">Side project collab</option>
							<option value="other">Other</option>
						</select>
					</div>
					<div class="field">
						<label for="message">Brief</label>
						<textarea id="message" name="message" required></textarea>
					</div>
					<button type="submit" class="btn btn-primary">Send brief →</button>
					<p class="form-note">
						Form powered by Formspree. By submitting, you agree to be contacted at the email you provided.
					</p>
				</form>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.hero-top {
		display: flex;
		justify-content: space-between;
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--ink-500);
		margin-bottom: 2rem;
	}
	.hero h1 { font-size: clamp(2.5rem, 7vw, 4.5rem); }
	.hero .lede { max-width: 50ch; }

	.contact-grid { align-items: start; gap: clamp(2rem, 5vw, 4rem); }

	.kv {
		display: grid;
		grid-template-columns: max-content 1fr;
		gap: 0.75rem 1.25rem;
		margin: 0;
	}
	.kv dt {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--ink-500);
	}
	.kv dd { margin: 0; font-size: var(--text-md); color: var(--ink-900); }
	.kv dd a { color: var(--ink-900); border-bottom: 1px solid var(--accent); }
	.kv dd a:hover { color: var(--accent); }

	.social-block { margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--rule); }
	.social-block .label { margin-bottom: 0.5rem; }
	.social-block li { margin-bottom: 0.4rem; }
	.social-block a {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.4rem 0;
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--ink-700);
	}
	.social-block a:hover { color: var(--accent); }
	.social-key { color: var(--ink-300); }

	.contact-form .field { margin-bottom: 1rem; }
	.contact-form .opt {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		text-transform: none;
		letter-spacing: 0;
		color: var(--ink-500);
		margin-left: 0.4rem;
	}
	.form-note {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--ink-500);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin: 1rem 0 0;
	}
</style>
