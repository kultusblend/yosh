---
import { SITE_TITLE, PROFILE, SOCIAL } from '../consts';
const year = new Date().getFullYear();
const lastBuild = new Date().toISOString().slice(0, 10);

const socialEntries = Object.entries(SOCIAL).filter(
	([, v]) => v && (v.startsWith('http') || v.includes('@')),
);
---

<footer class="site-footer">
	<div class="container">
		<hr class="rule-thick" />
		<div class="foot-grid">
			<div class="col col-brand">
				<p class="section-index"><span class="num">∎</span> {SITE_TITLE}</p>
				<p class="bio">{PROFILE.shortName}. {PROFILE.jobTitle}. Based in {PROFILE.location}, Malaysia.</p>
			</div>
			<div class="col">
				<p class="label">Sitemap</p>
				<ul class="list-clean">
					<li><a href="/">Index</a></li>
					<li><a href="/about/">About</a></li>
					<li><a href="/cv/">CV</a></li>
					<li><a href="/projects/">Projects</a></li>
					<li><a href="/contact/">Contact</a></li>
				</ul>
			</div>
			<div class="col">
				<p class="label">Contact</p>
				<ul class="list-clean">
					<li><a href={`mailto:${PROFILE.email}`}>{PROFILE.email}</a></li>
					{socialEntries.map(([key, val]) => (
						<li><a href={val.startsWith('http') ? val : `https://${val}`}>{key}</a></li>
					))}
				</ul>
			</div>
			<div class="col">
				<p class="label">Build</p>
				<ul class="list-clean">
					<li>v0.1.0</li>
					<li>Last built {lastBuild}</li>
					<li>Astro + Cloudflare Pages</li>
				</ul>
			</div>
		</div>
		<div class="foot-legal">
			<span>© {year} {PROFILE.shortName}. All rights reserved.</span>
			<span>{PROFILE.location} · MY</span>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: 5rem;
		padding-bottom: 2rem;
		background: var(--bg);
	}
	.foot-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1.5fr 1fr;
		gap: 2.5rem;
		padding: 2.5rem 0 1.5rem;
	}
	@media (max-width: 820px) {
		.foot-grid {
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
		}
		.col-brand { grid-column: 1 / -1; }
	}
	.col p.label { margin-bottom: 0.75rem; }
	.col .bio {
		color: var(--ink-700);
		font-size: var(--text-sm);
		max-width: 38ch;
		margin: 0.5rem 0 0;
	}
	.section-index .num { font-family: var(--font-mono); color: var(--accent); margin-right: 0.4em; }
	.list-clean a {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--ink-700);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
	.list-clean li {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--ink-500);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 0.45rem;
	}
	.foot-legal {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--rule);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--ink-500);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}
	@media (max-width: 600px) {
		.foot-legal { flex-direction: column; }
	}
</style>
