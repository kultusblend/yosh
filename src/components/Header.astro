---
import { SITE_TITLE } from '../consts';

const primaryNav = [
	{ href: '/about/', label: 'About', index: '01' },
	{ href: '/cv/',    label: 'CV',    index: '02' },
	{ href: '/projects/', label: 'Projects', index: '03' },
	{ href: '/contact/', label: 'Contact', index: '04' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
	href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
	<div class="container header-inner">
		<a href="/" class="brand" aria-label={`Halaman utama ${SITE_TITLE}`}>
			<span class="brand-prefix">→</span>
			<span class="brand-name">{SITE_TITLE}</span>
		</a>

		<nav class="primary-nav" aria-label="Navigasi utama">
			<ul>
				{primaryNav.map((item) => (
					<li>
						<a
							href={item.href}
							aria-current={isActive(item.href) ? 'page' : undefined}
						>
							<span class="nav-index">{item.index}</span>
							<span class="nav-label">{item.label}</span>
						</a>
					</li>
				))}
			</ul>
		</nav>

		<button
			type="button"
			class="menu-toggle"
			id="menu-toggle"
			aria-label="Buka menu"
			aria-expanded="false"
			aria-controls="mobile-drawer"
		>
			MENU
		</button>
	</div>
</header>

<div class="drawer-backdrop" id="drawer-backdrop" hidden></div>

<aside
	class="mobile-drawer"
	id="mobile-drawer"
	aria-label="Menu navigasi"
	aria-hidden="true"
	hidden
>
	<div class="drawer-head">
		<span class="drawer-title">MENU</span>
		<button
			type="button"
			class="drawer-close"
			id="drawer-close"
			aria-label="Tutup menu"
		>CLOSE</button>
	</div>
	<nav aria-label="Navigasi mobile">
		<ul class="drawer-nav">
			{primaryNav.map((item) => (
				<li>
					<a
						href={item.href}
						aria-current={isActive(item.href) ? 'page' : undefined}
						data-nav-link
					>
						<span class="nav-index">{item.index}</span>
						<span>{item.label}</span>
					</a>
				</li>
			))}
		</ul>
	</nav>
</aside>

<script>
	const toggle = document.getElementById('menu-toggle');
	const drawer = document.getElementById('mobile-drawer');
	const backdrop = document.getElementById('drawer-backdrop');
	const closeBtn = document.getElementById('drawer-close');

	const setOpen = (open: boolean) => {
		if (!toggle || !drawer || !backdrop) return;
		toggle.setAttribute('aria-expanded', String(open));
		drawer.setAttribute('aria-hidden', String(!open));
		document.body.classList.toggle('drawer-open', open);
		if (open) {
			drawer.hidden = false;
			backdrop.hidden = false;
			requestAnimationFrame(() => {
				drawer.classList.add('is-open');
				backdrop.classList.add('is-visible');
			});
			const firstLink = drawer.querySelector<HTMLAnchorElement>('a, button');
			firstLink?.focus();
		} else {
			drawer.classList.remove('is-open');
			backdrop.classList.remove('is-visible');
			setTimeout(() => {
				drawer.hidden = true;
				backdrop.hidden = true;
			}, 160);
			toggle.focus();
		}
	};

	toggle?.addEventListener('click', () => {
		const expanded = toggle.getAttribute('aria-expanded') === 'true';
		setOpen(!expanded);
	});
	closeBtn?.addEventListener('click', () => setOpen(false));
	backdrop?.addEventListener('click', () => setOpen(false));

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
			setOpen(false);
		}
	});

	drawer?.querySelectorAll<HTMLAnchorElement>('[data-nav-link]').forEach((link) => {
		link.addEventListener('click', () => setOpen(false));
	});
</script>

<style>
	/* Double-hairline editorial divider beneath the sticky header.
	   Two 1px lines separated by a 3px breath, dossier / book-cover feel.
	   Pseudo-element drawn directly below header sits in normal flow,
	   so the layout below shifts cleanly without overlap. */
	.site-header {
		background: var(--bg);
		border-bottom: var(--bw) solid var(--ink-900);
		position: sticky;
		top: 0;
		z-index: 50;
	}
	.site-header::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		top: 100%;
		margin-top: 3px;
		height: var(--bw);
		background: var(--ink-900);
	}
	.header-inner {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1.5rem;
		padding-top: 0.85rem;
		padding-bottom: 0.85rem;
	}
	.brand {
		display: inline-flex;
		align-items: baseline;
		gap: 0.45rem;
		color: var(--ink-900);
	}
	.brand-prefix {
		color: var(--accent);
		font-family: var(--font-mono);
		font-weight: 500;
	}
	.brand-name {
		font-family: var(--font-serif);
		font-style: italic;
		font-weight: 700;
		font-size: var(--text-lg);
		letter-spacing: -0.01em;
	}

	.primary-nav ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		gap: 0.25rem;
		justify-content: flex-end;
	}
	.primary-nav a {
		display: inline-flex;
		align-items: baseline;
		gap: 0.45rem;
		color: var(--ink-700);
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.5rem 0.7rem;
		border: 1px solid transparent;
		transition: color var(--transition), border-color var(--transition);
	}
	.primary-nav .nav-index {
		color: var(--ink-300);
		font-weight: 500;
	}
	.primary-nav a:hover, .primary-nav a:focus-visible {
		color: var(--accent);
	}
	.primary-nav a:hover .nav-index,
	.primary-nav a:focus-visible .nav-index {
		color: var(--accent);
	}
	.primary-nav a[aria-current='page'] {
		color: var(--ink-900);
		border-color: var(--ink-900);
	}
	.primary-nav a[aria-current='page'] .nav-index {
		color: var(--accent);
	}

	.menu-toggle {
		display: none;
		background: transparent;
		border: 1px solid var(--ink-900);
		padding: 0.5rem 0.75rem;
		color: var(--ink-900);
		cursor: pointer;
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.menu-toggle:hover, .menu-toggle:focus-visible {
		background: var(--ink-900);
		color: var(--surface);
	}

	@media (max-width: 820px) {
		.primary-nav { display: none; }
		.menu-toggle { display: inline-flex; align-items: center; }
	}

	.drawer-backdrop {
		position: fixed;
		inset: 0;
		background: rgba(10, 10, 9, 0.55);
		z-index: 60;
		opacity: 0;
		transition: opacity 160ms ease;
	}
	.drawer-backdrop.is-visible { opacity: 1; }

	.mobile-drawer {
		position: fixed;
		top: 0;
		right: 0;
		bottom: 0;
		width: min(86vw, 340px);
		background: var(--surface);
		border-left: 1px solid var(--ink-900);
		z-index: 70;
		transform: translateX(100%);
		transition: transform 160ms ease-out;
		display: flex;
		flex-direction: column;
		overflow-y: auto;
	}
	.mobile-drawer.is-open { transform: translateX(0); }

	.drawer-head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 1.25rem;
		border-bottom: 1px solid var(--ink-900);
	}
	.drawer-title {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		font-weight: 500;
		color: var(--ink-900);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.drawer-close {
		background: transparent;
		border: 1px solid var(--ink-900);
		padding: 0.4rem 0.7rem;
		color: var(--ink-900);
		cursor: pointer;
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.drawer-close:hover { background: var(--ink-900); color: var(--surface); }

	.drawer-nav {
		list-style: none;
		padding: 0.5rem 0;
		margin: 0;
		flex-grow: 1;
	}
	.drawer-nav a {
		display: flex;
		align-items: baseline;
		gap: 0.7rem;
		padding: 1rem 1.25rem;
		color: var(--ink-700);
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		border-bottom: 1px solid var(--rule);
	}
	.drawer-nav .nav-index { color: var(--ink-300); }
	.drawer-nav a:hover, .drawer-nav a:focus-visible {
		color: var(--accent);
		background: var(--surface-2);
	}
	.drawer-nav a[aria-current='page'] {
		color: var(--ink-900);
		border-left: 3px solid var(--accent);
		padding-left: calc(1.25rem - 3px);
	}
	.drawer-nav a[aria-current='page'] .nav-index { color: var(--accent); }

	:global(body.drawer-open) { overflow: hidden; }
</style>
